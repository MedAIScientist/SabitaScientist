# EvoScientist Production — copy to deploy/.env and fill in
# (API keys from ../.env are inherited automatically)

# LLM provider (pick at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Web search (optional)
TAVILY_API_KEY=

# Garage S3 (change these in production!)
GARAGE_ACCESS_KEY=GK1234567890abc
GARAGE_SECRET_KEY=abcdef1234567890abcdef1234567890
GARAGE_BUCKET=evoscientist

# PM database path (inside the /data volume)
EVOSCIENTIST_PM_DB=/data/pm.db
